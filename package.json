{
  "name": "@xiaokaixuan/random",
  "version": "1.1.2",
  "description": "一个极简的伪随机数生成器，支持自定义种子",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./index.d.ts"
    }
  },
  "files": [
    "index.d.ts",
    "dist"
  ],
  "scripts": {
    "test": "node test.js",
    "build": "rollup -c rollup.config.mjs && javascript-obfuscator dist/index.js --output dist/index.js --compact true --control-flow-flattening true && javascript-obfuscator dist/index.cjs --output dist/index.cjs --compact true --control-flow-flattening true",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "random",
    "seed",
    "pseudo-random",
    "deterministic",
    "xiaokaixuan"
  ],
  "author": "xiaokaixuan <xiaokaixuan24@163.com> (https://xiaokaixuan.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/coderxiao24/random.git"
  },
  "bugs": {
    "url": "https://github.com/coderxiao24/random/issues"
  },
  "homepage": "https://github.com/coderxiao24/random#readme",
  "engines": {
    "node": ">=10.0.0"
  },
  "devDependencies": {
    "javascript-obfuscator": "^5.4.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "rollup": "^4.60.4"
  },
  "dependencies": {
    "uuid": "^14.0.0"
  }
}
